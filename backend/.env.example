# Wygeneruj klucz:
#   python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
PDFTOOLS_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# Ścieżki (w Dockerze zostają domyślne, bare-metal np. $HOME/.pdftools/...)
PDFTOOLS_STORAGE_DIR=/var/lib/pdftools/sessions
PDFTOOLS_DB_PATH=/var/lib/pdftools/meta.db

# Ghostscript: na Linuksie "gs", na Windows "gswin64c"
PDFTOOLS_GHOSTSCRIPT_BIN=gs

# Limity / TTL
PDFTOOLS_MAX_UPLOAD_MB=200
PDFTOOLS_TTL_HOURS=24

# Blank-detect (opcjonalnie)
# PDFTOOLS_BLANK_TEXT_THRESHOLD=5
# PDFTOOLS_BLANK_PIXEL_STD_THRESHOLD=3.0
# PDFTOOLS_RENDER_DPI=100

# CORS (tylko jeśli frontend na innym hoście niż backend)
# PDFTOOLS_CORS_ORIGINS=https://pdftools.firma.local
